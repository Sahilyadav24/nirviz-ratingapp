# ─── Database ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nirviz
DB_USER=nirviz_user
DB_PASSWORD=changeme_strong_password

# Full URL is auto-built in config.py — no need to set manually
# DATABASE_URL=postgresql+asyncpg://nirviz_user:changeme@postgres:5432/nirviz

# ─── App ────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=changeme_32char_random_string_here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Meta Cloud API (WhatsApp Business) ─────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_API_VERSION=v19.0

# ─── Shopkeeper Notification ────────────────────────────────
SHOPKEEPER_PHONE=+919876543210        # WhatsApp number with country code

# ─── OTP Settings ───────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_MINUTES=10

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://www.google.com/search?kgmid=/g/11fm5mwd47&hl=en-IN&q=NIRVIZ+Resort+Fast+Food+%26+Cafe#lrd=0x396cb504665de0dd:0xfd42de1595380c62,3
